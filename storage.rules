rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{collection}/{docId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024
                   && collection in ['auditPlans', 'cpars', 'managementReviews', 'mocs', 'yearCycles', 'auditorProfiles', 'kpis', 'kpiReports', 'documents'];
    }
  }
}
